# ── App ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Clerk (https://clerk.com) ───────────────────
# Dashboard → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Stripe (https://stripe.com/docs/keys) ───────
# Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Dashboard → Products → create Pro + Enterprise products
# Copy the product ID (prod_...) for each
STRIPE_PRODUCT_PRO=prod_...
STRIPE_PRODUCT_ENTERPRISE=prod_...

# Local webhook secret from Stripe CLI:
#   STRIPE_API_KEY="sk_test_..." stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Copy the "whsec_..." secret it prints
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Neon Postgres (https://neon.tech) ───────────
# Dashboard → your project → Connection string (use the Pooler / pgbouncer URL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connection_limit=1

# ── Resend (https://resend.com) ─────────────────
# Dashboard → API Keys
RESEND_API_KEY=re_...
